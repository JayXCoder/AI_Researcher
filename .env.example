# Copy to .env and fill in. Do not commit .env — safe to push repo to public GitHub.
# run.sh and docker-compose read .env. Terraform gets values via TF_VAR_* exported by run.sh.

# ---------- Required for GCP deploy ----------
GCP_PROJECT=your-gcp-project-id

# Google Programmable Search Engine ID (from embed script: cx=XXXX in the URL)
GOOGLE_CX=your-google-cx

# GCP auth: path to service account JSON key file (for gcloud / Terraform)
GOOGLE_APPLICATION_CREDENTIALS=./your-project-key.json

# ---------- Secrets (store only in .env) ----------
# Custom Search API key: GCP Console → APIs & Services → Enable "Custom Search API" → Credentials → Create API key
# Or SerpAPI key from https://serpapi.com
SEARCH_API_KEY=

# ---------- Optional: after ./run.sh deploy-full ----------
# ARTIFACT_REGISTRY_REPO=us-central1-docker.pkg.dev/YOUR_PROJECT/perplexity-demo
# IMAGE_TAG=latest

# ---------- Optional for local Docker ----------
# BIGQUERY_DATASET=perplexity_logs
# GCS_BUCKET=perplexity-document-storage
